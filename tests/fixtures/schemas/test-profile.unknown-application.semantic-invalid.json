{
  "schemaVersion": 1,
  "id": "unknown-application",
  "platform": "windows-x64",
  "baselineType": "stock-clean",
  "artifact": { "fileNamePattern": "Sample-*.exe", "architecture": "x64" },
  "applications": [
    {
      "id": "sample-app",
      "installerType": "nsis",
      "installMode": "currentUser",
      "executableRelativePath": "AppData\\Local\\Sample\\Sample.exe",
      "uninstallerDiscovery": "hkcuUninstall"
    }
  ],
  "steps": [
    { "id": "stage-artifact", "type": "stageArtifact", "timeoutSeconds": 30 },
    { "id": "install-other", "type": "installPackage", "application": "other-app", "timeoutSeconds": 60 }
  ],
  "cleanupSteps": [],
  "manualAssertions": []
}
