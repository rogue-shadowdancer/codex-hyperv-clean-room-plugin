{
  "schemaVersion": 1,
  "id": "environment-path",
  "platform": "windows-x64",
  "baselineType": "stock-clean",
  "artifact": { "fileNamePattern": "Sample-*.exe", "architecture": "x64" },
  "applications": [
    {
      "id": "sample-app",
      "installerType": "nsis",
      "installMode": "currentUser",
      "executableRelativePath": "%USERPROFILE%\\Sample\\Sample.exe",
      "uninstallerDiscovery": "hkcuUninstall"
    }
  ],
  "steps": [
    { "id": "stage-artifact", "type": "stageArtifact", "timeoutSeconds": 30 }
  ],
  "cleanupSteps": [],
  "manualAssertions": []
}
