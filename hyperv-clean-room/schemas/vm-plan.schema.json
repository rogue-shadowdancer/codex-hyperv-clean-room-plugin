{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rogue-shadowdancer/codex-hyperv-clean-room-plugin/schemas/vm-plan.schema.json",
  "title": "Hyper-V clean-room VM creation plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "planKind",
    "planId",
    "createdAt",
    "expiresAt",
    "hostFingerprint",
    "isoPath",
    "isoSha256",
    "isoSizeBytes",
    "isoLastWriteTimeUtc",
    "switchName",
    "switchId",
    "name",
    "vmRoot",
    "vmPath",
    "vhdxPath",
    "targetVolume",
    "preconditions",
    "processorCount",
    "startupMemoryGb",
    "maximumMemoryGb",
    "diskSizeGb",
    "generation",
    "secureBoot",
    "vtpm"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "planKind": { "const": "vmCreate" },
    "planId": { "type": "string", "format": "uuid" },
    "createdAt": { "type": "string", "format": "date-time" },
    "expiresAt": { "type": "string", "format": "date-time" },
    "hostFingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "isoPath": { "type": "string", "minLength": 3, "maxLength": 32767 },
    "isoSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "isoSizeBytes": { "type": "integer", "minimum": 1 },
    "isoLastWriteTimeUtc": { "type": "string", "format": "date-time" },
    "switchName": { "type": "string", "minLength": 1, "maxLength": 256 },
    "switchId": { "type": "string", "minLength": 1, "maxLength": 256 },
    "name": { "type": "string", "minLength": 1, "maxLength": 100 },
    "vmRoot": { "type": "string", "minLength": 3, "maxLength": 32767 },
    "vmPath": { "type": "string", "minLength": 3, "maxLength": 32767 },
    "vhdxPath": { "type": "string", "minLength": 3, "maxLength": 32767 },
    "targetVolume": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uniqueId",
        "root",
        "fileSystem",
        "availableBytes",
        "requiredBytes"
      ],
      "properties": {
        "uniqueId": { "type": "string", "minLength": 1, "maxLength": 512 },
        "root": { "type": "string", "minLength": 3, "maxLength": 32767 },
        "fileSystem": { "type": "string", "minLength": 1, "maxLength": 64 },
        "availableBytes": { "type": "integer", "minimum": 0 },
        "requiredBytes": { "type": "integer", "minimum": 1 }
      }
    },
    "preconditions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "isoRegularFile",
        "switchPresent",
        "vmNameAbsent",
        "vmPathAbsent",
        "vhdxPathAbsent"
      ],
      "properties": {
        "isoRegularFile": { "const": true },
        "switchPresent": { "const": true },
        "vmNameAbsent": { "const": true },
        "vmPathAbsent": { "const": true },
        "vhdxPathAbsent": { "const": true }
      }
    },
    "processorCount": { "type": "integer", "minimum": 1, "maximum": 64 },
    "startupMemoryGb": { "type": "integer", "minimum": 2, "maximum": 256 },
    "maximumMemoryGb": { "type": "integer", "minimum": 2, "maximum": 512 },
    "diskSizeGb": { "type": "integer", "minimum": 40, "maximum": 2048 },
    "generation": { "const": 2 },
    "secureBoot": { "const": true },
    "vtpm": { "const": true }
  }
}
