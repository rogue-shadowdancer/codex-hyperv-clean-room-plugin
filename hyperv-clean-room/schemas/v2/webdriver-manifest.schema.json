{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rogue-shadowdancer/codex-hyperv-clean-room-plugin/contracts/v2/schemas/webdriver-manifest.schema.json",
  "title": "Hyper-V clean-room schema-v2 fixed WebDriver manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "provider",
    "browserKind",
    "browserVersion",
    "driverVersion",
    "architecture",
    "acquisition",
    "executable",
    "sessionPolicy",
    "files"
  ],
  "properties": {
    "schemaVersion": { "const": 2 },
    "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "provider": { "const": "microsoftEdgeDriver" },
    "browserKind": { "const": "fixedVersionWebView2" },
    "browserVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "driverVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "architecture": { "const": "x64" },
    "acquisition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "archiveFileName",
        "archiveSizeBytes",
        "archiveSha256",
        "redirectPolicy"
      ],
      "properties": {
        "source": { "const": "microsoftFixedEndpoint" },
        "archiveFileName": { "const": "edgedriver_win64.zip" },
        "archiveSizeBytes": { "type": "integer", "minimum": 1, "maximum": 536870912 },
        "archiveSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "redirectPolicy": { "const": "microsoftHttpsAllowlist" }
      }
    },
    "executable": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "relativePath",
        "sizeBytes",
        "sha256",
        "peArchitecture",
        "authenticodePublisher"
      ],
      "properties": {
        "relativePath": { "const": "msedgedriver.exe" },
        "sizeBytes": { "type": "integer", "minimum": 1, "maximum": 536870912 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "peArchitecture": { "const": "x64" },
        "authenticodePublisher": { "const": "Microsoft Corporation" }
      }
    },
    "sessionPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "listenAddress",
        "portPolicy",
        "browserArguments",
        "allowNavigation",
        "allowExecuteScript",
        "allowArbitrarySelector"
      ],
      "properties": {
        "listenAddress": { "const": "127.0.0.1" },
        "portPolicy": { "const": "serverAllocatedEphemeral" },
        "browserArguments": { "type": "array", "maxItems": 0 },
        "allowNavigation": { "const": false },
        "allowExecuteScript": { "const": false },
        "allowArbitrarySelector": { "const": false }
      }
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sizeBytes", "sha256"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1,
            "maxLength": 260,
            "pattern": "^(?![A-Za-z]:)(?![\\\\/])(?!.*:)(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).+$"
          },
          "sizeBytes": { "type": "integer", "minimum": 1, "maximum": 536870912 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    }
  }
}
