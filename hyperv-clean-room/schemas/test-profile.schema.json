{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rogue-shadowdancer/codex-hyperv-clean-room-plugin/schemas/test-profile.schema.json",
  "title": "Hyper-V clean-room declarative test profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "platform",
    "baselineType",
    "artifact",
    "applications",
    "steps",
    "manualAssertions"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "description": { "type": "string", "maxLength": 1000 },
    "platform": { "const": "windows-x64" },
    "baselineType": {
      "enum": ["stock-clean", "webview2-absent-derived"]
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fileNamePattern", "architecture"],
      "properties": {
        "fileNamePattern": {
          "type": "string",
          "minLength": 1,
          "maxLength": 260,
          "pattern": "^[^\\\\/]+$"
        },
        "architecture": { "const": "x64" },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "applications": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "installerType",
          "installMode",
          "executableRelativePath",
          "uninstallerDiscovery"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-zA-Z][a-zA-Z0-9-]*$" },
          "installerType": { "enum": ["nsis", "msi"] },
          "installMode": { "const": "currentUser" },
          "executableRelativePath": { "type": "string", "minLength": 1 },
          "uninstallerDiscovery": { "enum": ["hkcuUninstall", "msiProduct"] },
          "processName": { "type": "string", "pattern": "^[a-zA-Z0-9._-]+$" }
        }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/step" }
    },
    "manualAssertions": {
      "type": "array",
      "items": { "$ref": "#/$defs/manualAssertion" }
    }
  },
  "$defs": {
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "timeoutSeconds"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "type": {
          "enum": [
            "stageArtifact",
            "installPackage",
            "launchApplication",
            "stopApplication",
            "uninstallPackage",
            "assertFile",
            "assertRegistry",
            "assertProcess",
            "assertModule",
            "assertShortcut",
            "assertPort",
            "writeSentinel",
            "assertSentinel",
            "wait"
          ]
        },
        "application": { "type": "string", "pattern": "^[a-zA-Z][a-zA-Z0-9-]*$" },
        "timeoutSeconds": { "type": "integer", "minimum": 1, "maximum": 900 },
        "path": { "type": "string", "minLength": 1, "maxLength": 512 },
        "registryPath": { "type": "string", "minLength": 1, "maxLength": 512 },
        "registryName": { "type": "string", "maxLength": 255 },
        "expected": { "type": ["string", "number", "integer", "boolean", "null"] },
        "processName": { "type": "string", "pattern": "^[a-zA-Z0-9._-]+$" },
        "moduleRelativePath": { "type": "string", "minLength": 1, "maxLength": 512 },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "sentinelId": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "required": { "type": "boolean", "default": true }
      }
    },
    "manualAssertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description", "required"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "description": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "required": { "type": "boolean" }
      }
    }
  }
}
