{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rogue-shadowdancer/codex-hyperv-clean-room-plugin/schemas/test-profile.schema.json",
  "title": "Hyper-V clean-room declarative test profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "platform",
    "baselineType",
    "artifact",
    "applications",
    "steps",
    "cleanupSteps",
    "manualAssertions"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "$ref": "#/$defs/id" },
    "description": { "type": "string", "maxLength": 1000 },
    "platform": { "const": "windows-x64" },
    "baselineType": {
      "enum": ["stock-clean", "webview2-absent-derived"]
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fileNamePattern", "architecture"],
      "properties": {
        "fileNamePattern": {
          "type": "string",
          "minLength": 1,
          "maxLength": 260,
          "pattern": "^[^\\\\/]+$"
        },
        "architecture": { "const": "x64" },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "applications": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "installerType",
          "installMode",
          "executableRelativePath",
          "uninstallerDiscovery"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-zA-Z][a-zA-Z0-9-]*$" },
          "installerType": { "enum": ["nsis", "msi"] },
          "installMode": { "const": "currentUser" },
          "executableRelativePath": { "$ref": "#/$defs/safeRelativePath" },
          "uninstallerDiscovery": { "enum": ["hkcuUninstall", "msiProduct"] },
          "processName": { "type": "string", "pattern": "^[a-zA-Z0-9._-]+$" }
        }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/step" }
    },
    "cleanupSteps": {
      "type": "array",
      "maxItems": 16,
      "items": { "$ref": "#/$defs/cleanupStep" }
    },
    "manualAssertions": {
      "type": "array",
      "items": { "$ref": "#/$defs/manualAssertion" }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "safeRelativePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^(?![A-Za-z]:)(?![\\\\/])(?!.*:)(?!.*%)(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).+$"
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "timeoutSeconds"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "type": {
          "enum": [
            "stageArtifact",
            "installPackage",
            "launchApplication",
            "stopApplication",
            "uninstallPackage",
            "assertFile",
            "assertRegistry",
            "assertProcess",
            "assertModule",
            "assertShortcut",
            "assertPort",
            "writeSentinel",
            "assertSentinel",
            "wait"
          ]
        },
        "application": { "type": "string", "pattern": "^[a-zA-Z][a-zA-Z0-9-]*$" },
        "timeoutSeconds": { "type": "integer", "minimum": 1, "maximum": 900 },
        "path": { "$ref": "#/$defs/safeRelativePath" },
        "registryPath": { "$ref": "#/$defs/safeRelativePath" },
        "registryName": { "type": "string", "maxLength": 255 },
        "expected": { "type": ["string", "number", "integer", "boolean", "null"] },
        "processName": { "type": "string", "pattern": "^[a-zA-Z0-9._-]+$" },
        "moduleRelativePath": { "$ref": "#/$defs/safeRelativePath" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "sentinelId": { "$ref": "#/$defs/id" },
        "required": { "type": "boolean", "default": true }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "enum": [
                  "installPackage",
                  "launchApplication",
                  "stopApplication",
                  "uninstallPackage"
                ]
              }
            },
            "required": ["type"]
          },
          "then": { "required": ["application"] }
        },
        {
          "if": {
            "properties": { "type": { "enum": ["assertFile", "assertShortcut"] } },
            "required": ["type"]
          },
          "then": { "required": ["path"] }
        },
        {
          "if": {
            "properties": { "type": { "const": "assertRegistry" } },
            "required": ["type"]
          },
          "then": { "required": ["registryPath"] }
        },
        {
          "if": {
            "properties": { "type": { "const": "assertProcess" } },
            "required": ["type"]
          },
          "then": {
            "oneOf": [
              { "required": ["application"] },
              { "required": ["processName"] }
            ]
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "assertModule" } },
            "required": ["type"]
          },
          "then": { "required": ["application", "moduleRelativePath"] }
        },
        {
          "if": {
            "properties": { "type": { "const": "assertPort" } },
            "required": ["type"]
          },
          "then": { "required": ["port"] }
        },
        {
          "if": {
            "properties": {
              "type": { "enum": ["writeSentinel", "assertSentinel"] }
            },
            "required": ["type"]
          },
          "then": { "required": ["sentinelId"] }
        },
        {
          "if": {
            "properties": {
              "type": {
                "enum": [
                  "stageArtifact",
                  "installPackage",
                  "launchApplication",
                  "stopApplication",
                  "uninstallPackage",
                  "writeSentinel",
                  "wait"
                ]
              }
            },
            "required": ["type"]
          },
          "then": {
            "properties": { "required": { "const": true } }
          }
        }
      ]
    },
    "cleanupStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "timeoutSeconds"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "type": {
          "enum": [
            "stopApplication",
            "wait",
            "assertFile",
            "assertRegistry",
            "assertProcess",
            "assertModule",
            "assertShortcut",
            "assertPort",
            "assertSentinel"
          ]
        },
        "application": { "type": "string", "pattern": "^[a-zA-Z][a-zA-Z0-9-]*$" },
        "timeoutSeconds": { "type": "integer", "minimum": 1, "maximum": 120 },
        "path": { "$ref": "#/$defs/safeRelativePath" },
        "registryPath": { "$ref": "#/$defs/safeRelativePath" },
        "registryName": { "type": "string", "maxLength": 255 },
        "expected": { "type": ["string", "number", "integer", "boolean", "null"] },
        "processName": { "type": "string", "pattern": "^[a-zA-Z0-9._-]+$" },
        "moduleRelativePath": { "$ref": "#/$defs/safeRelativePath" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "sentinelId": { "$ref": "#/$defs/id" },
        "required": { "type": "boolean", "default": true }
      },
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "stopApplication" } },
            "required": ["type"]
          },
          "then": { "required": ["application"] }
        },
        {
          "if": {
            "properties": { "type": { "enum": ["assertFile", "assertShortcut"] } },
            "required": ["type"]
          },
          "then": { "required": ["path"] }
        },
        {
          "if": {
            "properties": { "type": { "const": "assertRegistry" } },
            "required": ["type"]
          },
          "then": { "required": ["registryPath"] }
        },
        {
          "if": {
            "properties": { "type": { "const": "assertProcess" } },
            "required": ["type"]
          },
          "then": {
            "oneOf": [
              { "required": ["application"] },
              { "required": ["processName"] }
            ]
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "assertModule" } },
            "required": ["type"]
          },
          "then": { "required": ["application", "moduleRelativePath"] }
        },
        {
          "if": {
            "properties": { "type": { "const": "assertPort" } },
            "required": ["type"]
          },
          "then": { "required": ["port"] }
        },
        {
          "if": {
            "properties": { "type": { "const": "assertSentinel" } },
            "required": ["type"]
          },
          "then": { "required": ["sentinelId"] }
        },
        {
          "if": {
            "properties": { "type": { "enum": ["stopApplication", "wait"] } },
            "required": ["type"]
          },
          "then": {
            "properties": { "required": { "const": true } }
          }
        }
      ]
    },
    "manualAssertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description", "required"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "description": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "required": { "type": "boolean" }
      }
    }
  }
}
