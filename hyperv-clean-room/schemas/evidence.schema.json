{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rogue-shadowdancer/codex-hyperv-clean-room-plugin/schemas/evidence.schema.json",
  "title": "Hyper-V clean-room evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "operationId",
    "createdAt",
    "profileId",
    "baselineType",
    "vm",
    "guest",
    "artifact",
    "automaticAssertions",
    "manualAssertions",
    "overallStatus",
    "warnings"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "operationId": { "type": "string", "format": "uuid" },
    "createdAt": { "type": "string", "format": "date-time" },
    "profileId": { "type": "string" },
    "baselineType": {
      "enum": ["stock-clean", "webview2-absent-derived"]
    },
    "vm": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "checkpointName", "ownershipVerified"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "checkpointName": { "type": ["string", "null"] },
        "ownershipVerified": { "type": "boolean" }
      }
    },
    "guest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "windowsBuild",
        "architecture",
        "userName",
        "isAdministrator",
        "isElevated",
        "tokenIntegrity"
      ],
      "properties": {
        "windowsBuild": { "type": "string" },
        "architecture": { "const": "x64" },
        "userName": { "type": "string" },
        "isAdministrator": { "type": "boolean" },
        "isElevated": { "type": "boolean" },
        "tokenIntegrity": { "enum": ["low", "medium", "high", "system"] },
        "profilePathContainsNonAscii": { "type": "boolean" }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fileName", "size", "sourceSha256", "guestSha256"],
      "properties": {
        "fileName": { "type": "string" },
        "size": { "type": "integer", "minimum": 0 },
        "sourceSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "guestSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "automaticAssertions": {
      "type": "array",
      "items": { "$ref": "#/$defs/automaticAssertion" }
    },
    "manualAssertions": {
      "type": "array",
      "items": { "$ref": "#/$defs/manualAssertion" }
    },
    "overallStatus": { "enum": ["passed", "failed", "incomplete"] },
    "warnings": {
      "type": "array",
      "items": { "type": "string", "maxLength": 1000 }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "overallStatus": { "const": "passed" } },
        "required": ["overallStatus"]
      },
      "then": {
        "properties": {
          "vm": {
            "properties": { "ownershipVerified": { "const": true } }
          },
          "guest": {
            "properties": {
              "isAdministrator": { "const": false },
              "isElevated": { "const": false },
              "tokenIntegrity": { "const": "medium" }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "automaticAssertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "required", "status", "summary", "evidence"],
      "properties": {
        "id": { "type": "string" },
        "required": { "type": "boolean" },
        "status": {
          "enum": ["passed", "failed", "notPerformed", "unsupported"]
        },
        "summary": { "type": "string", "maxLength": 2000 },
        "evidence": { "type": ["object", "null"] }
      }
    },
    "manualAssertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "required", "description", "status", "attestation"],
      "properties": {
        "id": { "type": "string" },
        "required": { "type": "boolean" },
        "description": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "status": {
          "enum": ["passed", "failed", "notPerformed", "unsupported"]
        },
        "attestation": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/attestation" }
          ]
        }
      },
      "oneOf": [
        {
          "properties": {
            "status": { "const": "notPerformed" },
            "attestation": { "type": "null" }
          }
        },
        {
          "properties": {
            "status": { "enum": ["passed", "failed"] },
            "attestation": {
              "allOf": [
                { "$ref": "#/$defs/attestation" },
                {
                  "properties": {
                    "method": {
                      "enum": [
                        "visualInspection",
                        "interactiveExercise",
                        "externalTool"
                      ]
                    }
                  }
                }
              ]
            }
          }
        },
        {
          "properties": {
            "status": { "const": "unsupported" },
            "attestation": {
              "allOf": [
                { "$ref": "#/$defs/attestation" },
                {
                  "properties": {
                    "method": { "const": "declaredUnsupported" }
                  }
                }
              ]
            }
          }
        }
      ]
    },
    "attestation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operationId",
        "profileId",
        "assertionId",
        "observer",
        "observedAt",
        "method",
        "summary",
        "evidenceReferences"
      ],
      "properties": {
        "operationId": { "type": "string", "format": "uuid" },
        "profileId": { "type": "string", "minLength": 1 },
        "assertionId": { "type": "string", "minLength": 1 },
        "observer": { "type": "string", "minLength": 1, "maxLength": 512 },
        "observedAt": { "type": "string", "format": "date-time" },
        "method": {
          "enum": [
            "visualInspection",
            "interactiveExercise",
            "externalTool",
            "declaredUnsupported"
          ]
        },
        "summary": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "evidenceReferences": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidenceReference" }
        }
      }
    },
    "evidenceReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512,
          "pattern": "^(?![A-Za-z]:)(?![\\\\/])(?!.*\\.\\.[\\\\/]).+$"
        },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    }
  }
}
