      },
      "resultContract": {
        "envelopeSchema": "https://github.com/rogue-shadowdancer/codex-hyperv-clean-room-plugin/contracts/v2/schemas/operation-envelope.schema.json",
        "successChanged": true,
        "successDataSchema": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "planId",
            "pairedPlanId",
            "planRole",
            "vmId",
            "vmName",
            "adapterId",
            "target",
            "previousAttachment",
            "currentAttachment",
            "effectState",
            "recoveryRequired"
          ],
          "properties": {
            "planId": { "type": "string", "format": "uuid" },
            "pairedPlanId": { "type": ["string", "null"], "format": "uuid" },
            "planRole": { "enum": ["change", "recovery"] },
            "vmId": { "type": "string", "minLength": 1, "maxLength": 256 },
            "vmName": { "type": "string", "minLength": 1, "maxLength": 100 },
            "adapterId": { "type": "string", "minLength": 1, "maxLength": 256 },
            "target": { "enum": ["baseline", "disconnected"] },
            "previousAttachment": {
              "$ref": "https://github.com/rogue-shadowdancer/codex-hyperv-clean-room-plugin/contracts/v2/schemas/vm-network-plan.schema.json#/$defs/attachment"
            },
            "currentAttachment": {
              "$ref": "https://github.com/rogue-shadowdancer/codex-hyperv-clean-room-plugin/contracts/v2/schemas/vm-network-plan.schema.json#/$defs/attachment"
            },
            "effectState": { "const": "confirmed" },
            "recoveryRequired": { "type": "boolean" }
          },
          "allOf": [
            {
              "if": {
                "properties": {
                  "planRole": { "const": "change" },
                  "target": { "const": "disconnected" }
                },
                "required": ["planRole", "target"]
              },
              "then": {
                "properties": {
                  "pairedPlanId": { "type": "string", "format": "uuid" },
                  "previousAttachment": { "$ref": "https://github.com/rogue-shadowdancer/codex-hyperv-clean-room-plugin/contracts/v2/schemas/vm-network-plan.schema.json#/$defs/connectedAttachment" },
                  "currentAttachment": { "$ref": "https://github.com/rogue-shadowdancer/codex-hyperv-clean-room-plugin/contracts/v2/schemas/vm-network-plan.schema.json#/$defs/disconnectedAttachment" },
                  "recoveryRequired": { "const": true }
                }
              },
              "else": {
                "properties": {
                  "previousAttachment": { "$ref": "https://github.com/rogue-shadowdancer/codex-hyperv-clean-room-plugin/contracts/v2/schemas/vm-network-plan.schema.json#/$defs/disconnectedAttachment" },
                  "currentAttachment": { "$ref": "https://github.com/rogue-shadowdancer/codex-hyperv-clean-room-plugin/contracts/v2/schemas/vm-network-plan.schema.json#/$defs/connectedAttachment" },
                  "recoveryRequired": { "const": false }
                }
              }
            },
            {
              "if": {
                "properties": { "planRole": { "const": "recovery" } },
                "required": ["planRole"]
              },
              "then": {
                "properties": {
                  "pairedPlanId": { "type": "string", "format": "uuid" },
                  "target": { "const": "baseline" }
                }
              }
            },
            {
              "if": {
                "properties": {
                  "planRole": { "const": "change" },
                  "target": { "const": "baseline" }
                },
                "required": ["planRole", "target"]
              },
              "then": { "properties": { "pairedPlanId": { "type": "null" } } }
            }
          ]
