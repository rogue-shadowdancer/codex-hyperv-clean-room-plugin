            "recoveryPlan": {
              "oneOf": [
                { "type": "null" },
                {
                  "allOf": [
                    {
                      "$ref": "https://github.com/rogue-shadowdancer/codex-hyperv-clean-room-plugin/contracts/v2/schemas/vm-network-plan.schema.json"
                    },
                    { "properties": { "planRole": { "const": "recovery" } } }
                  ]
                }
              ]
            }
          },
          "allOf": [
            {
              "if": {
                "properties": {
                  "changePlan": {
                    "properties": { "target": { "const": "disconnected" } }
                  }
                },
                "required": ["changePlan"]
              },
              "then": {
                "properties": {
                  "recoveryPlan": {
                    "allOf": [
                      {
                        "$ref": "https://github.com/rogue-shadowdancer/codex-hyperv-clean-room-plugin/contracts/v2/schemas/vm-network-plan.schema.json"
                      },
                      { "properties": { "planRole": { "const": "recovery" } } }
                    ]
                  }
                }
              },
              "else": {
                "properties": {
                  "changePlan": {
                    "properties": { "pairedPlanId": { "type": "null" } }
                  },
                  "recoveryPlan": { "type": "null" }
                }
              }
            }
          ]
