      "resultContract": {
        "envelopeSchema": "https://github.com/rogue-shadowdancer/codex-hyperv-clean-room-plugin/contracts/v2/schemas/operation-envelope.schema.json",
        "successChanged": false,
        "successDataSchema": {
          "type": "object",
          "additionalProperties": false,
          "required": ["changePlan", "recoveryPlan"],
          "properties": {
            "changePlan": {
              "allOf": [
                {
                  "$ref": "https://github.com/rogue-shadowdancer/codex-hyperv-clean-room-plugin/contracts/v2/schemas/vm-network-plan.schema.json"
                },
                { "properties": { "planRole": { "const": "change" } } }
              ]
